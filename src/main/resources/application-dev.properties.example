# ===============================
# APP CONFIGURATION
# ===============================
app.frontend.url=http://localhost:5173,http://localhost:5174,http://localhost:3000
app.url=http://localhost:8080

# ===============================
# POSTGRESQL / SUPABASE CONFIGURATION
# ===============================
spring.datasource.url=jdbc:postgresql://<host>/<db>?user=<user>&password=<password>&sslmode=require
spring.datasource.username=CHANGE_ME
spring.datasource.password=CHANGE_ME

# ===============================
# EMAIL CONFIGURATION (Gmail SMTP)
# ===============================
spring.mail.username=CHANGE_ME@gmail.com
spring.mail.password=CHANGE_ME_APP_PASSWORD

# ===============================
# JWT CONFIGURATION
# ===============================
jwt.secret=CHANGE_ME_BASE64_SECRET_MIN_32_CHARS
jwt.access-token.expiration=36000000

# ===============================
# CLOUDINARY CONFIGURATION
# ===============================
cloudinary.cloud-name=CHANGE_ME
cloudinary.api-key=CHANGE_ME
cloudinary.api-secret=CHANGE_ME

# ===============================
# RESEND CONFIGURATION
# ===============================
resend.api.key=CHANGE_ME
resend.from-email=no-reply@yourdomain.com
